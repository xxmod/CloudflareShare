{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://cloudflare-share.xxx.workers.dev"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}