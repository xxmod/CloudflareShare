name = "cloudflare-share"
main = "src/index.js"
compatibility_date = "2026-03-10"

[vars]
R2_ACCOUNT_ID = "此处为CF账户ID"
R2_BUCKET_NAME = "cloudflare-share-file"

[[d1_databases]]
binding = "DB"
database_name = "cloudflare-share-db"
database_id = "此处为D1数据库ID（创建时查看）"

[[r2_buckets]]
binding = "BUCKET"
bucket_name = "cloudflare-share-file"